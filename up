#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_PATH="${DOTFILES_PATH:-$SCRIPT_DIR}"
# Keep an existing asdf-era ~/.tool-versions from being merged into this
# repository's mise configuration during bootstrap.
export MISE_CEILING_PATHS="${MISE_CEILING_PATHS:-$HOME}"

print_header() {
  printf '\033[34m'
  cat <<'BANNER'
--------------------------------------------------------------------------------

                 888          888     .d888 d8b 888
                 888          888    d88P"  Y8P 888
                 888          888    888        888
             .d88888  .d88b.  888888 888888 888 888  .d88b.  .d8888b
            d88" 888 d88""88b 888    888    888 888 d8P  Y8b 88K
            888  888 888  888 888    888    888 888 88888888 "Y8888b.
            Y88b 888 Y88..88P Y88b.  888    888 888 Y8b.          X88
             "Y88888  "Y88P"   "Y888 888    888 888  "Y8888   88888P"

                           comfortable envs for you

                         github.com/hiramekun/dotfiles

--------------------------------------------------------------------------------
BANNER
  printf '\033[0m\n'
}

check_platform() {
  local xcode_check

  if [ "$(uname -s)" != "Darwin" ] || [ "$(uname -m)" != "arm64" ]; then
    printf 'This setup supports macOS on Apple Silicon only.\n' >&2
    exit 1
  fi

  if ! xcode-select -p >/dev/null 2>&1; then
    printf 'Install Xcode Command Line Tools with `xcode-select --install`, then rerun this script.\n' >&2
    exit 1
  fi

  xcode_check="$(/usr/bin/xcrun clang 2>&1 || true)"
  case "$xcode_check" in
    *license*)
      printf 'The Xcode license must be accepted.\n'
      sudo xcodebuild -license accept
      ;;
  esac
}

install_homebrew() {
  if ! command -v brew >/dev/null 2>&1; then
    printf 'Installing Homebrew...\n'
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi

  eval "$(/opt/homebrew/bin/brew shellenv)"
}

install_mise() {
  if brew list --formula mise >/dev/null 2>&1; then
    HOMEBREW_NO_ASK=1 brew upgrade mise
  else
    printf 'Installing mise...\n'
    HOMEBREW_NO_ASK=1 brew install mise
  fi
}

run_mise_task() {
  if [ "$#" -eq 0 ]; then
    set -- setup
  fi

  cd "$DOTFILES_PATH"
  mise trust "$DOTFILES_PATH/mise.toml"

  # setup installs Homebrew dependencies before mise-managed tools explicitly.
  # Disabling the task runner's eager installation preserves that ordering.
  MISE_TASK_RUN_AUTO_INSTALL=false mise run "$@"
}

main() {
  print_header
  check_platform
  install_homebrew
  install_mise
  run_mise_task "$@"
}

main "$@"
